# ═══════════════════════════════════════════════════════════
# GenAI Dashboard Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=genai_dashboard
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public
APP_SCHEMA=genai_app

# ── Ollama LLM ─────────────────────────────────────────────
AI_FACTORY_API=http://localhost:11434/v1
AI_FACTORY_MODEL=llama3.1:8b
EMBEDDINGS_API=http://localhost:11434/api/embeddings
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# ── Auth (optional for local) ──────────────────────────────
AUTH_ENABLED=false
JWT_SECRET=local-dev-secret-change-in-production
JWT_EXPIRE_MIN=1440

# ── Session ────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ── SQL Safety ─────────────────────────────────────────────
SQL_TIMEOUT_SEC=8
RECORD_WARN_THRESHOLD=5000

# ── File Upload ────────────────────────────────────────────
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=txt,json,xlsx,pdf,csv,docx
MAX_UPLOAD_STORAGE_MB=5000
EXPORT_FILE_TTL_HOURS=1

# ── RAG Chunking ───────────────────────────────────────────
CHUNK_SIZE=1600
CHUNK_OVERLAP=320

# ── Input Quality ──────────────────────────────────────────
GIBBERISH_THRESHOLD=0.4
GIBBERISH_HARD_THRESHOLD=0.7
MAX_INPUT_LENGTH=10000

# ── FAISS Vector Search ────────────────────────────────────
FAISS_IVF_THRESHOLD=10000
FAISS_IVF_NCENTROIDS=100
FAISS_IVF_NPROBE=10
RETRIEVAL_CACHE_TTL_MIN=30

# ── Schema Watch ───────────────────────────────────────────
SCHEMA_WATCH_INTERVAL_MIN=15

# ── Database Pool ──────────────────────────────────────────
DB_POOL_MIN=1
DB_POOL_MAX=5

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=*
