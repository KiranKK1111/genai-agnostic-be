# ═══════════════════════════════════════════════════════════
# GenAI Dashboard Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=kittu
POSTGRES_SCHEMA=mstr
APP_SCHEMA=mstr_app

# ── Ollama LLM ─────────────────────────────────────────────
AI_FACTORY_API=http://localhost:11434/v1
AI_FACTORY_TOKEN=
AI_FACTORY_MODEL=llama3.1:latest
# Local sentence encoder — no external model, no downloads
EMBEDDING_MODEL=local-sentence-encoder
EMBEDDING_DIMENSIONS=384

# ── Auth (optional for local) ──────────────────────────────
AUTH_ENABLED=true
JWT_SECRET=sdb-genai-f7k2m9x4p1q8w3v6n0r5t
JWT_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_MIN=60

# ── Session ────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# ── SQL Safety ─────────────────────────────────────────────
SQL_TIMEOUT_SEC=8
RECORD_WARN_THRESHOLD=5000

# ── File Upload ────────────────────────────────────────────
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=txt,json,xlsx,pdf,csv,docx
MAX_UPLOAD_STORAGE_MB=5000
EXPORT_FILE_TTL_HOURS=1

# ── RAG Chunking ───────────────────────────────────────────
CHUNK_SIZE=1600
CHUNK_OVERLAP=320

# ── Input Quality ──────────────────────────────────────────
GIBBERISH_THRESHOLD=0.4
GIBBERISH_HARD_THRESHOLD=0.7
MAX_INPUT_LENGTH=10000

# ── FAISS Vector Search ────────────────────────────────────
FAISS_IVF_THRESHOLD=10000
FAISS_IVF_NCENTROIDS=100
FAISS_IVF_NPROBE=10
RETRIEVAL_CACHE_TTL_MIN=30

# ── Schema Watch ───────────────────────────────────────────
SCHEMA_WATCH_INTERVAL_MIN=15

# ── Database Pool ──────────────────────────────────────────
DB_POOL_MIN=1
DB_POOL_MAX=5